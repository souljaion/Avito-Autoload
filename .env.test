# Test environment — used by pytest.
# Copy to .env before running tests, or:
#   cp .env.test .env && pytest && git checkout .env
#
# Create the test database:
#   createdb -U avito_user -h localhost -p 5433 avito_autoload_test
#   DATABASE_URL=postgresql+asyncpg://avito_user:avito_pass@localhost:5433/avito_autoload_test \
#       alembic upgrade head

DATABASE_URL=postgresql+asyncpg://avito_user:avito_pass@localhost:5433/avito_autoload_test
BASE_URL=http://localhost:8001
MEDIA_DIR=./media
FEEDS_DIR=./feeds
SECRET_KEY=test-secret-key-not-for-production-use-only-testing-1234567890abcdef
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=testpass123
ENCRYPTION_KEY=
CRM_DSN=
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
